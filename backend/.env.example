# ─── Anthropic API ───────────────────────────────────────────────────────────
# Claude API キー（AI チャット・OMR 機能に必要）
# https://console.anthropic.com/ で取得してください
ANTHROPIC_API_KEY=sk-ant-...

# ─── CORS ────────────────────────────────────────────────────────────────────
# フロントエンドのオリジンをカンマ区切りで指定（Vercel デプロイ URL など）
# 例: https://your-app.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
