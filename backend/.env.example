# ─── Anthropic API ───────────────────────────────────────────────────────────
# Claude API キー（AI チャット・OMR 機能に必要）
# https://console.anthropic.com/ で取得してください
ANTHROPIC_API_KEY=sk-ant-...

# ─── CORS ────────────────────────────────────────────────────────────────────
# フロントエンドのオリジンをカンマ区切りで指定（Vercel デプロイ URL など）
# 例: https://your-app.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Stripe シークレットキー (Dashboard > Developers > API keys)
STRIPE_SECRET_KEY=sk_test_...

# Stripe Webhook シークレット (stripe listen --forward-to ... で取得するローカル用)
# 本番は Dashboard > Developers > Webhooks で確認
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price ID (Dashboard > Products > 各プランの Price ID)
STRIPE_PRICE_ID_STARTER=price_xxx
STRIPE_PRICE_ID_PRO=price_yyy
STRIPE_PRICE_ID_PREMIUM=price_zzz

# Stripe Checkout の success_url / cancel_url に使用するフロントエンドURL
FRONTEND_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
# 開発: SQLite (デフォルト)。本番: PostgreSQL を必ず設定すること。
#
# ⚠ 重要: SQLite のままで Koyeb などのエフェメラルコンテナで動かすと、
# コンテナ再起動のたびに UsageLog (AI/PDF 使用量) が全部消え、
# Free ユーザーが AI 回数上限をバイパスできる (無限に使える) 事故になる。
#
# 本番では必ず Neon / Supabase / Railway などの永続化 PostgreSQL を使う:
#   DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
#
# FRONTEND_URL が localhost 以外を指しているのに SQLite のままだと、
# バックエンドは起動時に ERROR ログで警告し、/api/health と
# /api/subscription/db-health の `persistence_at_risk` が true になる。
# 本当に止めたい場合は ENFORCE_DB_PERSISTENCE=1 を追加すると起動を拒否する。
DATABASE_URL=sqlite:///./eddivom.db

# ─── 内部通信認証 ─────────────────────────────────────────────────────────────
# Next.js → FastAPI のサーバー間通信を認証するランダム文字列
# フロントエンドの INTERNAL_API_SECRET と同じ値を設定してください
INTERNAL_API_SECRET=
